# ~/.bashrc: executed by bash(1) for non-login shells.
#
# API keys and secrets do NOT belong here.
# Store them in ~/.secrets (not tracked by git) and source it from ~/.profile:
#   [ -f "$HOME/.secrets" ] && source "$HOME/.secrets"

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=2000

[ -n "$BASH_VERSION" ] && shopt -s checkwinsize

# make less more friendly for non-text input files
[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

# enable color support of ls
if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

if [ -f ~/.functions ]; then
    . ~/.functions
fi

#if [ -f ~/dotfiles/bash/machine-connect.sh ]; then
#    . ~/dotfiles/bash/machine-connect.sh
#fi

if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi
export PATH="$PATH:$HOME/bin:$HOME/.local/bin"

# Auto-start tmux for local sessions only (SSH sessions skip to avoid nesting)
if [[ -z "$TMUX" && -z "$SSH_TTY" ]]; then
    tmux attach -t default 2>/dev/null || tmux new-session -s default
fi

if [ -d "/home/linuxbrew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Disable passwordless sudo if it was left enabled
if [ -f /etc/sudoers.d/doc-nopasswd ]; then
    sudo toggle-sudo disable
fi

# Auto-enter DailyUse distrobox on t480i5 only
# Exit the container to reach a host shell; use NO_DISTROBOX=1 to skip
if [[ "$HOSTNAME" == "t480i5" ]] && [[ -z "$CONTAINER_ID" ]] && [[ -z "$NO_DISTROBOX" ]] && [[ $- == *i* ]]; then
    distrobox enter DailyUse
fi
