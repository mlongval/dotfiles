source $HOME/.profile
source $HOME/.functions
source $HOME/.bash_aliases

# Disable passwordless sudo if it was left enabled
if [ -f /etc/sudoers.d/doc-nopasswd ]; then
    sudo toggle-sudo disable
fi

# Auto-enter DailyUse distrobox on t480i5 only
# Exit the container to reach a host shell; use NO_DISTROBOX=1 to skip
if [[ "$HOST" == "t480i5" ]] && [[ -z "$CONTAINER_ID" ]] && [[ -z "$NO_DISTROBOX" ]] && [[ $- == *i* ]]; then
    if ! distrobox list | grep -q "DailyUse"; then
        distrobox create --name DailyUse --image registry.fedoraproject.org/fedora:latest --volume /var/home/linuxbrew:/home/linuxbrew:ro --yes
    fi
    distrobox enter DailyUse
fi

# Greeting
command -v fastfetch >/dev/null 2>&1 && fastfetch -l none

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# History
HISTFILE=~/.histfile
HISTSIZE=1000
SAVEHIST=1000

# Vi mode
bindkey -v
bindkey -M viins 'jk' vi-cmd-mode

# Completion
zstyle :compinstall filename '$HOME/.zshrc'
autoload -Uz compinit
compinit
zstyle ':completion:*' menu select
fpath+=~/.zfunc

# Powerlevel10k
# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
source ~/dotfiles/powerlevel10k/powerlevel10k.zsh-theme

# Bun
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# Linuxbrew
if [ -d "/home/linuxbrew" ]; then
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi


export PATH="$HOME/.npm-global/bin:$PATH"

# OpenClaw Completion
[ -f "/var/home/doc/.openclaw/completions/openclaw.zsh" ] && source "/var/home/doc/.openclaw/completions/openclaw.zsh"
