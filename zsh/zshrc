[ -s "/home/doc/.bun/_bun" ] && source "/home/doc/.bun/_bun"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

zstyle ':completion:*' menu select
fpath+=~/.zfunc

bindkey -M viins 'jk' vi-cmd-mode
if [ -d "/home/linuxbrew" ]
